  updatedAt               DateTime  @updatedAt
  
  @@index([staffId])
  @@index([expiryDate])
  @@index([isExpired])
}

// Training Records
model training_records {
  id                      String    @id
  staffId                 String
  staffName               String
  trainingName            String
  trainingType            String    // mandatory, optional, departmental
  provider                String
  startDate               DateTime
  endDate                 DateTime
